# Copy to web/.env.local (git-ignored) and fill the password from docker/.env.
# Read-only Postgres connection for the cockpit. Never commit the real value.
DATABASE_URL=postgresql://realdeal_admin:YOUR_POSTGRES_PASSWORD@127.0.0.1:5432/realdeal_os

# Public site
# Canonical origin for metadata/sitemap (prod: the live domain).
NEXT_PUBLIC_SITE_URL=http://localhost:3000
# Wix Headless OAuth Client ID (Wix dashboard -> Settings -> Headless).
# Optional: without it the site serves local fixture content.
WIX_CLIENT_ID=

# Newsletter double-opt-in confirm emails (optional: without a key, signups are
# recorded as pending and no email is sent). Same key as docker/.env RESEND_API_KEY.
RESEND_API_KEY=
EMAIL_FROM=Padmini Jain <padmini@realdealhousing.com>
