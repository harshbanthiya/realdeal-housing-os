{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "components/cards/**",
              "components/chrome/**",
              "components/core/**",
              "components/marketing/**",
              "components/motion/**",
              "ui_kits/cockpit/**",
              "ui_kits/website-motion/**",
              "ui_kits/website/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:Montserrat|IBM Plex Mono))/i]",
        "message": "Font not provided by the design system. Available: Montserrat, IBM Plex Mono."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute > JSXIdentifier[name!=/^(?:variant|size|href|onClick|children|style|key|ref|className|style|children)$/]",
        "message": "<Button> doesn't accept that prop. Declared props: variant, size, href, onClick, children, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:primary|outline|warm)$/]",
        "message": "<Button> variant must be one of 'primary' | 'outline' | 'warm'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md)$/]",
        "message": "<Button> size must be one of 'sm' | 'md'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Card'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|radius|padding|style|key|ref|className|style|children)$/]",
        "message": "<Card> doesn't accept that prop. Declared props: children, radius, padding, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='CountUp'] > JSXAttribute > JSXIdentifier[name!=/^(?:value|prefix|suffix|duration|style|key|ref|className|style|children)$/]",
        "message": "<CountUp> doesn't accept that prop. Declared props: value, prefix, suffix, duration, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Dot'] > JSXAttribute > JSXIdentifier[name!=/^(?:tone|style|key|ref|className|style|children)$/]",
        "message": "<Dot> doesn't accept that prop. Declared props: tone, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Eyebrow'] > JSXAttribute > JSXIdentifier[name!=/^(?:n|label|onDark|key|ref|className|style|children)$/]",
        "message": "<Eyebrow> doesn't accept that prop. Declared props: n, label, onDark."
      },
      {
        "selector": "JSXOpeningElement[name.name='ListingCard'] > JSXAttribute > JSXIdentifier[name!=/^(?:title|location|config|sqft|price|type|src|key|ref|className|style|children)$/]",
        "message": "<ListingCard> doesn't accept that prop. Declared props: title, location, config, sqft, price, type, src."
      },
      {
        "selector": "JSXOpeningElement[name.name='ListingCard'] > JSXAttribute[name.name='type'] > Literal[value!=/^(?:sale|rent)$/]",
        "message": "<ListingCard> type must be one of 'sale' | 'rent'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Mono'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|size|title|style|key|ref|className|style|children)$/]",
        "message": "<Mono> doesn't accept that prop. Declared props: children, size, title, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='PanelTitle'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|hint|key|ref|className|style|children)$/]",
        "message": "<PanelTitle> doesn't accept that prop. Declared props: children, hint."
      },
      {
        "selector": "JSXOpeningElement[name.name='Parallax'] > JSXAttribute > JSXIdentifier[name!=/^(?:speed|children|style|key|ref|className|style|children)$/]",
        "message": "<Parallax> doesn't accept that prop. Declared props: speed, children, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='PendingChip'] > JSXAttribute > JSXIdentifier[name!=/^(?:token|key|ref|className|style|children)$/]",
        "message": "<PendingChip> doesn't accept that prop. Declared props: token."
      },
      {
        "selector": "JSXOpeningElement[name.name='Pill'] > JSXAttribute > JSXIdentifier[name!=/^(?:tone|children|style|key|ref|className|style|children)$/]",
        "message": "<Pill> doesn't accept that prop. Declared props: tone, children, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='PlaceholderFrame'] > JSXAttribute > JSXIdentifier[name!=/^(?:ratio|label|src|alt|radius|style|children|key|ref|className|style|children)$/]",
        "message": "<PlaceholderFrame> doesn't accept that prop. Declared props: ratio, label, src, alt, radius, style, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='ProjectCard'] > JSXAttribute > JSXIdentifier[name!=/^(?:name|location|meta|href|src|key|ref|className|style|children)$/]",
        "message": "<ProjectCard> doesn't accept that prop. Declared props: name, location, meta, href, src."
      },
      {
        "selector": "JSXOpeningElement[name.name='Reveal'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|delay|style|key|ref|className|style|children)$/]",
        "message": "<Reveal> doesn't accept that prop. Declared props: children, delay, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='RevealImage'] > JSXAttribute > JSXIdentifier[name!=/^(?:src|alt|ratio|radius|delay|style|key|ref|className|style|children)$/]",
        "message": "<RevealImage> doesn't accept that prop. Declared props: src, alt, ratio, radius, delay, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='RevealLines'] > JSXAttribute > JSXIdentifier[name!=/^(?:lines|as|delay|style|lineStyle|key|ref|className|style|children)$/]",
        "message": "<RevealLines> doesn't accept that prop. Declared props: lines, as, delay, style, lineStyle."
      },
      {
        "selector": "JSXOpeningElement[name.name='SiteHeader'] > JSXAttribute > JSXIdentifier[name!=/^(?:nav|phone|active|key|ref|className|style|children)$/]",
        "message": "<SiteHeader> doesn't accept that prop. Declared props: nav, phone, active."
      },
      {
        "selector": "JSXOpeningElement[name.name='StatusBadge'] > JSXAttribute > JSXIdentifier[name!=/^(?:status|key|ref|className|style|children)$/]",
        "message": "<StatusBadge> doesn't accept that prop. Declared props: status."
      },
      {
        "selector": "JSXOpeningElement[name.name='StatusBadge'] > JSXAttribute[name.name='status'] > Literal[value!=/^(?:operator_confirmed|pending_review|pending)$/]",
        "message": "<StatusBadge> status must be one of 'operator_confirmed' | 'pending_review' | 'pending'."
      },
      {
        "selector": "JSXOpeningElement[name.name='StickyCta'] > JSXAttribute > JSXIdentifier[name!=/^(?:hidden|onRequest|whatsappHref|key|ref|className|style|children)$/]",
        "message": "<StickyCta> doesn't accept that prop. Declared props: hidden, onRequest, whatsappHref."
      },
      {
        "selector": "JSXOpeningElement[name.name='Ticker'] > JSXAttribute > JSXIdentifier[name!=/^(?:items|speed|style|itemStyle|key|ref|className|style|children)$/]",
        "message": "<Ticker> doesn't accept that prop. Declared props: items, speed, style, itemStyle."
      }
    ]
  },
  "overrides": [
    {
      "files": [
        "**/index.js"
      ],
      "rules": {
        "no-restricted-imports": "off"
      }
    }
  ],
