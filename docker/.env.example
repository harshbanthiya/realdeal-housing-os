# Copy this file to docker/.env and replace every change_me value before starting.
# Keep docker/.env private. It is ignored by Git.

TZ=Asia/Kolkata

POSTGRES_DB=realdeal_os
POSTGRES_USER=realdeal_admin
POSTGRES_PASSWORD=change_me_use_a_long_random_password
POSTGRES_PORT=5432

N8N_DB=realdeal_n8n
N8N_IMAGE=docker.n8n.io/n8nio/n8n:latest
N8N_PORT=5678
N8N_ENCRYPTION_KEY=change_me_32_plus_random_characters

NOCODB_DB=realdeal_nocodb
NOCODB_PORT=8080
NC_AUTH_JWT_SECRET=change_me_32_plus_random_characters

ADMINER_PORT=8081
