# macOS, external-drive, and editor noise
.DS_Store
._*
.AppleDouble
.LSOverride
.Spotlight-V100/
.Trashes/
*.swp
*.swo
.vscode/
.idea/

# Logs
*.log
logs/

# Local environment and secrets
.env
.env.*
*.env
*.env.*
docker/.env
!.env.example
!*.env.example
!docker/.env.example
secrets/
*.key
*.pem
*.p12
*.pfx
*.crt
*.cer
*.der
*.jks
*.keystore
id_rsa*
id_ed25519*

# Persistent app and database state
data/
backups/

# Temporary workspace and generated script outputs (never commit)
.codex_tmp/
outputs/

# Private imports, client files, and generated outputs
imports/
exports/
clients/
client-data/
client-files/
client_files/
contact-data/
contact_data/
contacts/
# Exception: cockpit app SOURCE lives under a dir named "contacts" — it is code,
# not contact data, so re-include it. (Data still lives in exports/ + imports/,
# which stay ignored above. Keep this before the **/._* rule at EOF.)
!web/src/app/cockpit/contacts/
!web/src/app/cockpit/contacts/**
leads/
owners/
private/
raw/

# Private property media
media/
*.mp4
*.mov
*.m4v
*.avi
*.webm
*.mkv
*.jpg
*.jpeg
*.png
*.heic
*.heif
*.gif
*.tif
*.tiff
*.webp
*.psd
*.ai

# Contact/client data files
*.csv
*.tsv
*.xls
*.xlsx
*.xlsm
*.ods
*.vcf
*.numbers

# Keep fake example import templates trackable while real imports stay ignored.
!imports/
!imports/contacts/
imports/contacts/raw_archives/
imports/contacts/raw_samples/
!imports/contacts/*.csv.example
!imports/contacts/*.vcf.example
# Raw property data subdirs — contain PII/registration data (PDFs, XLS), never commit.
imports/buildings/
imports/igr Registrations/
imports/mahaRera/
imports/inventory/

# Database dumps and local database files
*.dump
*.backup
*.bak
*.sql.gz
*.sql.zip
*.psql
*.db
*.sqlite
*.sqlite3
*dump*.sql
*backup*.sql

# Node / Python junk
node_modules/
__pycache__/
*.pyc
.venv/
venv/

# n8n exports can accidentally include credential references or secrets.
workflows/n8n/*credentials*.json
workflows/n8n/*secret*.json

# Phase 6.10 RERA Playwright snapshots and browser artifacts (raw, untrusted, never committed).
# (exports/ above already covers exports/rera_snapshots/, but be explicit and also catch
#  Playwright traces/videos/cache that could land outside exports/.)
exports/rera_snapshots/
**/rera_snapshots/
# Phase 6.18 IGR eSearch Index II snapshots (raw, untrusted, contain party PII — never committed).
exports/igr_snapshots/
**/igr_snapshots/
playwright-report/
test-results/
*.webm
trace.zip
*.trace.zip
.cache/ms-playwright/
ms-playwright/
.playwright/

# Explicitly keep project configuration and source artifacts trackable.
!docker/docker-compose.yml
!docker/.env.example
!README.md
!docs/
!docs/**
!schemas/
!schemas/**
!scripts/
!scripts/**
!workflows/
!workflows/**
!prompts/
!prompts/**
!start.sh
!stop.sh

# Re-ignore macOS AppleDouble files even inside allowlisted source folders.
**/._*

# Wix MCP connector config — user-scope only, never commit
.mcp.json

# Re-exclude python cache even though scripts/ is allowlisted
!scripts/__pycache__/
scripts/__pycache__/

# Per-machine Claude Code settings (local only)
.claude/settings.local.json
